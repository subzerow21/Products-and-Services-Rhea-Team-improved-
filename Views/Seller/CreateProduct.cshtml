@model MyAspNetApp.Models.DbProduct
@{
    ViewData["Title"] = "Manage Product Listing";
    Layout = null;
    var mode = ViewBag.Mode as string ?? "create";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NEXT HORIZON - Manage Product Listing</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>

    <style>
        :root {
            --main-bg: #ffffff;
            --input-bg: #AFAFB3;
            --text-dark: #111;
            --accent-red: #c5221f;
        }

        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background-color: var(--main-bg);
            color: var(--text-dark);
        }

        /* Top Navigation Menu */
        .top-nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 40px;
            border-bottom: 1px solid #eee;
        }

        .logo {
            font-weight: 800;
            font-style: italic;
            font-size: 1.4rem;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .nav-actions {
            display: flex;
            align-items: center;
            gap: 25px;
        }

        /* Main Container */
        .container {
            max-width: 900px;
            margin: 0 auto;
            padding: 40px 20px 100px 20px;
        }

        h2.page-title {
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 30px;
        }

        /* Image Upload Section */
        .main-upload-box {
            width: 100%;
            height: 350px;
            background-color: var(--input-bg);
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 15px;
            cursor: pointer;
            margin-bottom: 20px;
            transition: 0.2s;
        }

            .main-upload-box:hover {
                background-color: #a0a0a5;
            }

            .main-upload-box i {
                font-size: 6rem;
                color: #444;
            }

            .main-upload-box span {
                font-size: 1.4rem;
                font-weight: 600;
                color: #222;
            }

        /* Thumbnail Row */
        .thumbnail-row {
            display: flex;
            gap: 15px;
            margin-bottom: 40px;
            overflow-x: auto;
            padding: 10px 0;
        }

            .thumbnail-row::-webkit-scrollbar {
                height: 6px;
            }

            .thumbnail-row::-webkit-scrollbar-track {
                background: transparent;
            }

            .thumbnail-row::-webkit-scrollbar-thumb {
                background: #bbb;
                border-radius: 10px;
            }

                .thumbnail-row::-webkit-scrollbar-thumb:hover {
                    background: #888;
                }

        .thumbnail {
            width: 85px;
            height: 85px;
            background-color: var(--input-bg);
            border-radius: 10px;
            flex-shrink: 0;
            position: relative;
            overflow: hidden;
            cursor: pointer;
        }

            .thumbnail img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        /* Delete Button on Hover */
        .delete-btn {
            position: absolute;
            top: 5px;
            right: 5px;
            background: rgba(0, 0, 0, 0.7);
            color: white;
            border: none;
            border-radius: 50%;
            width: 22px;
            height: 22px;
            display: none;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            cursor: pointer;
            transition: 0.2s;
        }

            .delete-btn:hover {
                background: var(--accent-red);
            }

        .thumbnail:hover .delete-btn {
            display: flex;
        }

        /* Form Details */
        /* Product Details Header Layout */
        .details-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        h3.section-title {
            font-size: 1.4rem;
            font-weight: 700;
            margin: 0; /* Reset margin since wrapper handles spacing */
        }

        .form-row {
            margin-bottom: 15px;
        }

        .custom-input {
            width: 100%;
            background-color: var(--input-bg);
            border: none;
            padding: 20px 25px;
            border-radius: 12px;
            font-family: 'Inter', sans-serif;
            font-size: 1.05rem;
            color: #222;
            box-sizing: border-box;
            outline: none;
        }

            .custom-input::placeholder {
                color: #444;
                font-weight: 400;
            }

        /* Price / Discount Flex Row */
        .split-input-box {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background-color: var(--input-bg);
            border-radius: 12px;
            padding: 5px 25px;
        }

            .split-input-box input {
                background: transparent;
                border: none;
                font-family: 'Inter', sans-serif;
                font-size: 1.05rem;
                padding: 15px 0;
                outline: none;
                color: #222;
            }

                /* Remove up/down arrows from number inputs */
                .split-input-box input[type="number"]::-webkit-outer-spin-button,
                .split-input-box input[type="number"]::-webkit-inner-spin-button {
                    -webkit-appearance: none;
                    margin: 0;
                }

                .split-input-box input[type="number"] {
                    -moz-appearance: textfield;
                }

                .split-input-box input::placeholder {
                    color: #444;
                }

        .discount-wrap {
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .discount-wrap input {
                width: 60px;
                text-align: left;
            }

        /* Variant Row */
        .variant-row {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 15px;
        }

        .btn-plus-square {
            width: 55px;
            height: 55px;
            background-color: var(--input-bg);
            border: none;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: #333;
            cursor: pointer;
            flex-shrink: 0;
            overflow: hidden;
            padding: 0;
        }

            .btn-plus-square:hover {
                background-color: #a0a0a5;
            }

        .small-input {
            background-color: var(--input-bg);
            border: none;
            padding: 18px 15px;
            border-radius: 12px;
            font-family: 'Inter', sans-serif;
            font-size: 1rem;
            color: #222;
            outline: none;
            flex: 1;
            min-width: 70px;
        }

            .small-input::placeholder {
                color: #444;
            }

        .availability-label {
            font-weight: 700;
            margin-left: 5px;
            margin-right: 5px;
        }

        /* Interactive Custom Radio Styling */
        .custom-radio {
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            font-weight: 500;
            user-select: none;
            font-size: 0.9rem;
        }

            .custom-radio input {
                display: none;
            }

        .radio-box {
            width: 25px;
            height: 25px;
            background-color: var(--input-bg);
            border-radius: 6px;
            transition: background-color 0.2s;
        }

        .custom-radio input:checked + .radio-box {
            background-color: #000;
        }

        /* Add Size & Style Button Row */
        .add-variant-row {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 15px;
        }

        .btn-add-variant {
            flex: 1;
            background-color: var(--input-bg);
            border: none;
            padding: 20px;
            border-radius: 12px;
            font-family: 'Inter', sans-serif;
            font-size: 1.05rem;
            color: #333;
            cursor: pointer;
            text-align: center;
        }

            .btn-add-variant:hover {
                background-color: #a0a0a5;
            }

        .size-guide-link {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.85rem;
            cursor: pointer;
            width: 80px;
            text-decoration: none;
            color: inherit;
        }

            .size-guide-link i {
                font-size: 1.6rem;
                margin-top: 4px;
            }

        /* Bottom Row Split: Text Area & Barcode */
        .bottom-details-row {
            display: flex;
            gap: 15px;
            margin-bottom: 20px;
        }

        textarea.custom-input {
            flex: 1;
            height: 180px;
            resize: none;
            margin-bottom: 0; /* Remove margin inside flex */
        }

        .barcode-preview-box {
            width: 220px;
            background-color: var(--input-bg);
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 20px;
        }

            .barcode-preview-box span {
                font-weight: 700;
                color: #111;
                margin-bottom: 15px;
            }

            .barcode-preview-box svg {
                width: 100%;
                height: auto;
            }

        /* Action Buttons */
        .action-buttons {
            display: flex;
            justify-content: flex-end;
            gap: 15px;
        }

        .btn-submit {
            background-color: #1a1a1a;
            color: #fff;
            border: none;
            padding: 20px 60px;
            border-radius: 12px;
            font-family: 'Inter', sans-serif;
            font-size: 1.1rem;
            font-weight: 500;
            cursor: pointer;
            transition: 0.2s;
        }

            .btn-submit:hover {
                background-color: #000;
            }

        .btn-cancel {
            background-color: #fff;
            color: #111;
            border: 1px solid #111;
            padding: 20px 60px;
            border-radius: 12px;
            font-family: 'Inter', sans-serif;
            font-size: 1.1rem;
            font-weight: 500;
            cursor: pointer;
            transition: 0.2s;
        }

            .btn-cancel:hover {
                background-color: #f5f5f5;
            }

        /* Modal */
        .overlay-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.6);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }

        .overlay-content {
            background: #fff;
            padding: 30px;
            border-radius: 16px;
            max-width: 600px;
            width: 90%;
            text-align: center;
        }

            .overlay-content h3 {
                margin-top: 0;
                margin-bottom: 20px;
            }

        .grid-selector {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
            gap: 15px;
            margin-bottom: 20px;
            max-height: 400px;
            overflow-y: auto;
        }

            .grid-selector img {
                width: 100%;
                aspect-ratio: 1;
                object-fit: cover;
                border-radius: 10px;
                cursor: pointer;
                border: 2px solid transparent;
            }

                .grid-selector img:hover {
                    border-color: #111;
                }

        .close-modal {
            background: #111;
            color: #fff;
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
        }

        .close-modal-cancel {
            background: #fff;
            color: #111;
            padding: 10px 20px;
            border: 1px solid #111;
            border-radius: 8px;
            cursor: pointer;
            font-family: inherit;
            font-size: 0.95rem;
        }

        .img-selectable {
            position: relative;
            cursor: pointer;
            border-radius: 10px;
            overflow: hidden;
            border: 2px solid transparent;
        }

            .img-selectable img {
                width: 100%;
                aspect-ratio: 1;
                object-fit: cover;
                display: block;
            }

            .img-selectable:hover {
                border-color: #999;
            }

            .img-selectable.selected {
                border-color: #111;
            }

        .img-checkmark {
            position: absolute;
            top: 5px;
            right: 5px;
            width: 22px;
            height: 22px;
            background: #111;
            color: #fff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: bold;
            pointer-events: none;
        }
    </style>
</head>
<body>

    <header class="top-nav">
        <div class="logo">
            <div style="background: black; color: white; padding: 2px 10px; border-radius: 6px;">H</div>
            NEXT HORIZON
        </div>
        <div class="nav-actions">
            <i class="fa-regular fa-bell" style="font-size: 1.4rem; cursor: pointer;"></i>
            <div style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
                <i class="fa-regular fa-circle-user" style="font-size: 1.8rem;"></i>
                <span style="font-weight: 600;">Seller</span>
                <i class="fa-solid fa-chevron-down" style="font-size: 0.7rem;"></i>
            </div>
        </div>
    </header>

    <div class="container">
        <h2 class="page-title" id="dynamic-page-title">Create Product Listing</h2>

        <form asp-action="CreateProduct" asp-controller="Seller" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" name="mode" value="@mode" />
        <input type="hidden" asp-for="ProductId" />
        <input type="hidden" asp-for="Status" value="@(mode == "relist" ? "active" : (Model.Status ?? "active"))" />

        <input type="file" id="imageInput" name="imageFile" multiple accept="image/*" style="display: none;">

        <div class="main-upload-box" id="uploadBox">
            <i class="fa-solid fa-cloud-arrow-up"></i>
            <span>Upload Photos</span>
        </div>

        <div class="thumbnail-row" id="thumbnailRow">
        </div>

        <h3 class="section-title" style="margin-bottom: 15px;">Product Details</h3>

        <div class="form-row">
            <input type="text" class="custom-input" placeholder="Product Name" asp-for="ProductName" value="@Model.ProductName">
        </div>

        <div class="form-row" style="margin-bottom: 5px;">
            <div class="split-input-box">
                <input type="number" id="basePrice" placeholder="Price" min="0" step="any" asp-for="Price" value="@(Model.Price > 0 ? Model.Price.ToString("0.##") : "")">
                <div class="discount-wrap">
                    <span style="color: #444;">Discount % |</span>
                    <input type="number" id="discountPercent" placeholder="0" min="0" max="100" asp-for="Discount" value="@(Model.Discount.HasValue && Model.Discount.Value > 0 ? Model.Discount.Value.ToString("0.##") : "")">
                </div>
            </div>
            <div style="text-align: right; font-size: 0.95rem; color: #555; padding-right: 10px; margin-top: 8px;">
                Final Price: <span id="finalPriceDisplay" style="font-weight: 700; color: #111;">0.00</span>
            </div>
        </div>

        <div class="form-row">
            <input list="category-options" class="custom-input" asp-for="Category" value="@Model.Category" placeholder="Search or select a Category...">
            <datalist id="category-options">
                <option value="Tops"></option>
                <option value="Bottoms"></option>
                <option value="Outerwear"></option>
                <option value="Dresses & Jumpsuits"></option>
                <option value="Activewear"></option>
                <option value="Footwear"></option>
                <option value="Accessories"></option>
            </datalist>
        </div>

        <div class="form-row">
            <input type="text" class="custom-input" asp-for="Brand" value="@Model.Brand" placeholder="Brand (e.g. Nike, Adidas, Unbranded)">
        </div>

        <input type="hidden" id="hiddenProductUpc" name="UPC" value="">

        <div id="variants-container">
            <div class="variant-row">
                <button type="button" class="btn-plus-square"><i class="fa-solid fa-plus" style="font-weight: 300;"></i></button>
                <input type="text" class="small-input sku-field" id="primarySkuField" placeholder="SKU |">
                <input type="text" class="small-input" id="sizesInput" name="colorSizes" placeholder="Size |" value="@Model.Sizes">
                <input type="text" class="small-input" name="colorNames" placeholder="Style |">
                <input type="text" class="small-input qty-input" id="quantityInput" placeholder="Quantity |" value="@(Model.Stock > 0 ? Model.Stock.ToString() : "")">

                <span class="availability-label">Availability</span>

                <label class="custom-radio">
                    <input type="radio" name="availability-0" checked>
                    <div class="radio-box"></div>
                    In Stock
                </label>
                <label class="custom-radio">
                    <input type="radio" name="availability-0">
                    <div class="radio-box"></div>
                    Pre Order
                </label>
            </div>
        </div>

        <div class="add-variant-row">
            <button type="button" class="btn-add-variant" id="btnAddVariant">Add Size & Style</button>
            <a href="/Seller/SizeGuide" class="size-guide-link">
                Size Guide
                <i class="fa-solid fa-ruler-horizontal"></i>
            </a>
        </div>

        <input type="hidden" asp-for="Sizes" id="sizesHidden" />
        <input type="hidden" asp-for="Stock" id="stockHidden" />

        <div class="bottom-details-row">
            <textarea class="custom-input" placeholder="Product Details" asp-for="Details">@Model.Details</textarea>

            <div class="barcode-preview-box">
                <span>Barcode Preview</span>
                <svg id="liveBarcodePreview"></svg>
            </div>
        </div>

        <div class="action-buttons">
            <button type="button" class="btn-cancel" onclick="window.history.back()">Cancel</button>
            <button type="submit" class="btn-submit" id="dynamic-submit-btn">Add Product</button>
        </div>

        </form>
    </div>

    <div class="overlay-modal" id="imageModal">
        <div class="overlay-content">
            <h3>Select Variant Image</h3>
            <div class="grid-selector" id="modalGrid">
            </div>
            <div style="display:flex; gap:10px; justify-content:center; margin-top:5px;">
                <button type="button" class="close-modal-cancel" onclick="closeImageModal()">Cancel</button>
                <button type="button" class="close-modal" onclick="confirmImageSelection()">Done</button>
            </div>
        </div>
    </div>

    <script>
        // 0. Dynamic Page Logic & Live Barcode Generator
        document.addEventListener('DOMContentLoaded', () => {
            const mode = '@mode';

            const pageTitle = document.getElementById('dynamic-page-title');
            const submitBtn = document.getElementById('dynamic-submit-btn');

            if (mode === 'edit') {
                pageTitle.innerText = 'Edit Product Listing';
                submitBtn.innerText = 'Update Product';
            } else if (mode === 'renew') {
                pageTitle.innerText = 'Renew Product Listing';
                submitBtn.innerText = 'Renew Product';
            } else if (mode === 'relist') {
                pageTitle.innerText = 'Relist Product Listing';
                submitBtn.innerText = 'Relist Product';
            } else {
                pageTitle.innerText = 'Create Product Listing';
                submitBtn.innerText = 'Add Product';
            }

            // --- Auto Generate UPC and Render Barcode ---
            const generatedUpc = generateUPC();
            document.getElementById('hiddenProductUpc').value = generatedUpc; // Save to hidden field
            updateBarcodePreview(generatedUpc); // Draw the barcode immediately

            // Generate a starting SKU for the first variant row
            const firstSkuField = document.getElementById('primarySkuField');
            if(firstSkuField && !firstSkuField.value) {
                firstSkuField.value = generateSKU();
            }
        });

        // Function to generate the Barcode via JSBarcode
        function updateBarcodePreview(upcValue) {
            const svgTarget = document.getElementById("liveBarcodePreview");

            if (!upcValue || upcValue.trim() === '') {
                svgTarget.innerHTML = '';
                return;
            }

            try {
                JsBarcode("#liveBarcodePreview", upcValue.trim(), {
                    format: "CODE128",
                    lineColor: "#000000",
                    background: "transparent",
                    width: 2,
                    height: 50,
                    displayValue: true,
                    fontSize: 14,
                    font: "Inter",
                    margin: 0
                });
            } catch (error) {
                svgTarget.innerHTML = '';
            }
        }

        // Generate an alphanumeric SKU for variants
        function generateSKU() {
            return 'SKU-' + Math.random().toString(36).substr(2, 6).toUpperCase();
        }

        // Generate a 12-digit numeric UPC for the product barcode
        function generateUPC() {
            return Math.floor(100000000000 + Math.random() * 900000000000).toString();
        }

        // --- Price and Discount Logic ---
        const priceInput = document.getElementById('basePrice');
        const discountInput = document.getElementById('discountPercent');
        const finalPriceDisplay = document.getElementById('finalPriceDisplay');

        function blockInvalidNumberInput(e) {
            if (['e', 'E', '+', '-'].includes(e.key)) {
                e.preventDefault();
            }
        }

        function calculateFinalPrice() {
            let price = parseFloat(priceInput.value) || 0;
            let discount = parseFloat(discountInput.value) || 0;

            if (discount > 100) {
                discount = 100;
                discountInput.value = 100;
            }

            const finalPrice = price - (price * (discount / 100));
            finalPriceDisplay.innerText = finalPrice.toFixed(2);
        }

        priceInput.addEventListener('keydown', blockInvalidNumberInput);
        discountInput.addEventListener('keydown', blockInvalidNumberInput);
        priceInput.addEventListener('input', calculateFinalPrice);
        discountInput.addEventListener('input', calculateFinalPrice);

        // 1. Image Upload & Display Logic
        const uploadBox = document.getElementById('uploadBox');
        const imageInput = document.getElementById('imageInput');
        const thumbnailRow = document.getElementById('thumbnailRow');
        let selectedMainFiles = [];

        uploadBox.addEventListener('click', () => {
            imageInput.click();
        });

        function syncMainFileInput() {
            const dt = new DataTransfer();
            selectedMainFiles.forEach(file => dt.items.add(file));
            imageInput.files = dt.files;
        }

        function renderMainThumbnails() {
            thumbnailRow.innerHTML = '';
            selectedMainFiles.forEach((file, index) => {
                const imageUrl = URL.createObjectURL(file);
                const thumbDiv = document.createElement('div');
                thumbDiv.className = 'thumbnail';
                thumbDiv.innerHTML = `
                    <img src="${imageUrl}" alt="Uploaded Photo">
                    <button type="button" class="delete-btn" onclick="removeMainThumbnail(${index})">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                `;
                thumbnailRow.appendChild(thumbDiv);
            });
        }

        imageInput.addEventListener('change', function(event) {
            const files = event.target.files;
            for (let i = 0; i < files.length; i++) {
                selectedMainFiles.push(files[i]);
            }
            syncMainFileInput();
            renderMainThumbnails();
        });

        window.removeMainThumbnail = function(index) {
            const removedFile = selectedMainFiles[index];
            selectedMainFiles.splice(index, 1);
            // Remove this file from any variant that had it selected
            for (const [row, files] of variantImageMap.entries()) {
                if (files.has(removedFile)) {
                    files.delete(removedFile);
                    updateVariantButtonDisplay(row);
                }
            }
            syncMainFileInput();
            renderMainThumbnails();
        };


        // 2. Dynamic Variant Row Logic
        const btnAddVariant = document.getElementById('btnAddVariant');
        const variantsContainer = document.getElementById('variants-container');
        let variantIdCounter = 0;

        btnAddVariant.addEventListener('click', () => {
            variantIdCounter++;
            const newRow = document.createElement('div');
            newRow.className = 'variant-row';
            const newSku = generateSKU();

            newRow.innerHTML = `
                <button type="button" class="btn-plus-square"><i class="fa-solid fa-plus" style="font-weight: 300;"></i></button>
                <input type="text" class="small-input sku-field" value="${newSku}" placeholder="SKU |">
                <input type="text" class="small-input" name="colorSizes" placeholder="Size |">
                <input type="text" class="small-input" name="colorNames" placeholder="Style |">
                <input type="text" class="small-input qty-input" placeholder="Quantity |">

                <span class="availability-label">Availability</span>

                <label class="custom-radio">
                    <input type="radio" name="availability-${variantIdCounter}" checked>
                    <div class="radio-box"></div>
                    In Stock
                </label>
                <label class="custom-radio">
                    <input type="radio" name="availability-${variantIdCounter}">
                    <div class="radio-box"></div>
                    Pre Order
                </label>

                <button type="button" onclick="removeVariantRow(this.parentElement)" style="background:none; border:none; color:var(--accent-red); font-size:1.2rem; cursor:pointer; margin-left: 5px;">
                    <i class="fa-solid fa-trash"></i>
                </button>
            `;
            variantsContainer.appendChild(newRow);
        });

        // Auto-toggle In Stock / Pre Order when quantity changes
        variantsContainer.addEventListener('input', function(e) {
            const qtyField = e.target.closest('.qty-input');
            if (!qtyField) return;
            const row = qtyField.closest('.variant-row');
            if (!row) return;
            const qty = parseInt(qtyField.value, 10);
            const radios = row.querySelectorAll('input[type="radio"]');
            if (radios.length >= 2) {
                radios[0].checked = (qty > 0 || isNaN(qty) || qtyField.value.trim() === '');
                radios[1].checked = (!isNaN(qty) && qty === 0 && qtyField.value.trim() !== '');
            }
        });

        document.querySelector('form').addEventListener('submit', (e) => {
            // Compute global Sizes as union of all per-color sizes (for backward compat)
            const allSizeInputs = Array.from(variantsContainer.querySelectorAll('.variant-row input[name="colorSizes"]'));
            const allSizeValues = allSizeInputs.flatMap(inp => (inp.value || '').split(',').map(s => s.trim()).filter(Boolean));
            const uniqueSizes = [...new Set(allSizeValues)];
            document.getElementById('sizesHidden').value = uniqueSizes.join(',');

            const rows = Array.from(variantsContainer.querySelectorAll('.variant-row'));
            const allQtys = rows.reduce((sum, row) => sum + (parseInt(row.querySelector('.qty-input')?.value || '0', 10) || 0), 0);
            document.getElementById('stockHidden').value = allQtys;

            rows.forEach((row, i) => {
                // Append colorStocks[] hidden input
                const qty = parseInt(row.querySelector('.qty-input')?.value || '0', 10) || 0;
                const si = document.createElement('input');
                si.type = 'hidden';
                si.name = 'colorStocks';
                si.value = qty;
                e.target.appendChild(si);

                // Attach selected color images as named file inputs
                const files = variantImageMap.get(row) || new Set();
                if (files.size > 0) {
                    const dt = new DataTransfer();
                    for (const file of files) {
                        dt.items.add(file);
                    }
                    const fi = document.createElement('input');
                    fi.type = 'file';
                    fi.name = `colorFiles_${i}`;
                    fi.multiple = true;
                    fi.style.display = 'none';
                    fi.files = dt.files;
                    e.target.appendChild(fi);
                }
            });
        });

        // 3. Select Picture for specific variant Logic
        const imageModal = document.getElementById('imageModal');
        const modalGrid = document.getElementById('modalGrid');
        let currentVariantBtn = null;
        let currentVariantRow = null;
        const variantImageMap = new Map(); // Map<rowElement, Set<File>>

        variantsContainer.addEventListener('click', function(e) {
            const btn = e.target.closest('.btn-plus-square');
            if (btn) {
                currentVariantBtn = btn;
                currentVariantRow = btn.closest('.variant-row');
                openImageSelector();
            }
        });

        function openImageSelector() {
            modalGrid.innerHTML = '';

            if (selectedMainFiles.length === 0) {
                modalGrid.innerHTML = '<p style="grid-column: 1 / -1; color: #555;">Please upload some photos first using the big cloud box above.</p>';
                imageModal.style.display = 'flex';
                return;
            }

            // Collect files already assigned to other variant rows
            const usedByOthers = new Set();
            for (const [row, files] of variantImageMap.entries()) {
                if (row !== currentVariantRow) {
                    files.forEach(f => usedByOthers.add(f));
                }
            }

            const currentSelected = variantImageMap.get(currentVariantRow) || new Set();

            selectedMainFiles.forEach((file) => {
                if (usedByOthers.has(file)) return; // hidden — assigned to another variant

                const url = URL.createObjectURL(file);
                const wrapper = document.createElement('div');
                wrapper.className = 'img-selectable' + (currentSelected.has(file) ? ' selected' : '');

                const img = document.createElement('img');
                img.src = url;

                const checkmark = document.createElement('div');
                checkmark.className = 'img-checkmark';
                checkmark.textContent = '✓';
                checkmark.style.display = currentSelected.has(file) ? 'flex' : 'none';

                wrapper.onclick = () => {
                    const sel = variantImageMap.get(currentVariantRow) || new Set();
                    if (sel.has(file)) {
                        sel.delete(file);
                        wrapper.classList.remove('selected');
                        checkmark.style.display = 'none';
                    } else {
                        sel.add(file);
                        wrapper.classList.add('selected');
                        checkmark.style.display = 'flex';
                    }
                    variantImageMap.set(currentVariantRow, sel);
                };

                wrapper.appendChild(img);
                wrapper.appendChild(checkmark);
                modalGrid.appendChild(wrapper);
            });

            imageModal.style.display = 'flex';
        }

        function closeImageModal() {
            imageModal.style.display = 'none';
        }

        function confirmImageSelection() {
            updateVariantButtonDisplay(currentVariantRow);
            imageModal.style.display = 'none';
        }

        function updateVariantButtonDisplay(row) {
            const btn = row.querySelector('.btn-plus-square');
            const files = variantImageMap.get(row) || new Set();
            if (files.size === 0) {
                btn.innerHTML = '<i class="fa-solid fa-plus" style="font-weight:300;"></i>';
                btn.style.position = '';
                return;
            }
            const firstFile = Array.from(files)[0];
            const url = URL.createObjectURL(firstFile);
            const badge = files.size > 1
                ? `<div style="position:absolute;top:3px;right:3px;background:#111;color:#fff;border-radius:50%;width:20px;height:20px;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;">+${files.size - 1}</div>`
                : '';
            btn.style.position = 'relative';
            btn.innerHTML = `<img src="${url}" style="width:100%;height:100%;object-fit:cover;border-radius:inherit;">${badge}`;
        }

        function removeVariantRow(row) {
            variantImageMap.delete(row);
            row.remove();
        }
    </script>

</body>
</html>

