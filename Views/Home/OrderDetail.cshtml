@model MyAspNetApp.Models.OrderConfirmationViewModel

@{
    ViewData["Title"] = "Order " + Model.OrderId;
}

@section Styles {
<style>
    .detail-page {
        max-width: 720px;
        margin: 0 auto;
        padding: 40px 24px 80px;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: #888;
        text-decoration: none;
        margin-bottom: 24px;
        transition: color .15s;
    }
    .back-link:hover { color: #0a0a0a; }

    .detail-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 28px;
        flex-wrap: wrap;
        gap: 12px;
    }
    .detail-title {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 26px;
        font-weight: 700;
        letter-spacing: 1px;
    }
    .detail-date { font-size: 12px; color: #888; margin-top: 4px; }

    .status-pill-lg {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 8px 16px;
        border-radius: 24px;
        font-size: 13px;
        font-weight: 700;
    }
    .status-dot-lg {
        width: 8px; height: 8px;
        border-radius: 50%;
        background: currentColor;
    }

    .detail-card {
        border: 1.5px solid #e8e8e8;
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 16px;
    }
    .detail-section { padding: 20px 24px; }
    .detail-section + .detail-section { border-top: 1px solid #e8e8e8; }

    .section-title {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #888;
        margin-bottom: 14px;
    }

    /* Tracking */
    .track-steps {
        display: flex;
        align-items: flex-start;
        margin-bottom: 8px;
    }
    .track-step {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        flex: 1;
        position: relative;
    }
    .track-step:not(:last-child)::after {
        content: '';
        position: absolute;
        top: 16px;
        left: 50%;
        width: 100%;
        height: 2px;
        background: #e8e8e8;
        z-index: 0;
    }
    .track-step.done:not(:last-child)::after { background: #0a0a0a; }

    .track-dot {
        width: 32px; height: 32px;
        border-radius: 50%;
        border: 2px solid #e8e8e8;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        z-index: 1;
        font-size: 14px;
    }
    .track-dot.active  { background: #0a0a0a; border-color: #0a0a0a; color: #fff; }
    .track-dot.done-bg { background: #f5f5f5; border-color: #0a0a0a; }

    .track-label {
        font-size: 11px;
        color: #888;
        white-space: nowrap;
        text-align: center;
    }
    .track-step.done .track-label { color: #0a0a0a; font-weight: 600; }

    /* Info grid */
    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }
    .info-label {
        font-size: 11px;
        color: #888;
        margin-bottom: 3px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .5px;
    }
    .info-value { font-size: 14px; color: #0a0a0a; font-weight: 500; }

    /* Items */
    .detail-item {
        display: flex;
        gap: 12px;
        align-items: center;
        margin-bottom: 14px;
    }
    .detail-item-img {
        width: 56px; height: 56px;
        border-radius: 7px;
        object-fit: cover;
        background: #f5f5f5;
        flex-shrink: 0;
    }
    .detail-item-info { flex: 1; }
    .detail-item-name { font-size: 13px; font-weight: 600; }
    .detail-item-sub  { font-size: 12px; color: #888; }
    .detail-item-qty {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #f0f0f0;
        border-radius: 4px;
        padding: 1px 7px;
        font-size: 12px;
        font-weight: 700;
        color: #0a0a0a;
        margin-top: 4px;
    }
    .detail-item-price { font-size: 13px; font-weight: 700; margin-left: auto; }

    /* Totals */
    .total-row {
        display: flex;
        justify-content: space-between;
        font-size: 13px;
        color: #3a3a3a;
        margin-bottom: 8px;
    }
    .total-row.grand {
        font-size: 17px;
        font-weight: 700;
        color: #0a0a0a;
        padding-top: 12px;
        margin-top: 4px;
        border-top: 1px solid #e8e8e8;
    }

    /* Payment badge */
    .payment-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #f5f5f5;
        border-radius: 5px;
        padding: 6px 12px;
        font-size: 13px;
        font-weight: 600;
    }

    /* Actions */
    .detail-actions {
        display: flex;
        gap: 12px;
        margin-top: 8px;
        flex-wrap: wrap;
    }
    .btn-black {
        flex: 1;
        background: #0a0a0a;
        color: #fff;
        padding: 13px;
        text-align: center;
        border-radius: 6px;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
        font-family: 'Inter', sans-serif;
        transition: background .2s;
    }
    .btn-black:hover { background: #333; color: #fff; }

    .btn-outline {
        flex: 1;
        border: 1.5px solid #0a0a0a;
        color: #0a0a0a;
        padding: 13px;
        text-align: center;
        border-radius: 6px;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
        font-family: 'Inter', sans-serif;
        transition: all .2s;
    }
    .btn-outline:hover { background: #0a0a0a; color: #fff; }

    .btn-cancel {
        flex: 1;
        border: 1.5px solid #ef4444;
        color: #ef4444;
        padding: 13px;
        text-align: center;
        border-radius: 6px;
        font-size: 14px;
        font-weight: 700;
        background: none;
        cursor: pointer;
        font-family: 'Inter', sans-serif;
        transition: all .2s;
    }
    .btn-cancel:hover { background: #ef4444; color: #fff; }
    .btn-cancel:disabled {
        border-color: #d4d4d4;
        color: #aaa;
        cursor: not-allowed;
        background: #fafafa;
    }

    /* Cancel modal */
    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.45);
        z-index: 999;
        align-items: center;
        justify-content: center;
    }
    .modal-overlay.open { display: flex; }
    .modal-box {
        background: #fff;
        border-radius: 12px;
        padding: 28px;
        width: 100%;
        max-width: 440px;
        box-shadow: 0 20px 60px rgba(0,0,0,.18);
        animation: modalIn .2s ease;
    }
    @@keyframes modalIn {
        from { transform: translateY(16px); opacity: 0; }
        to   { transform: translateY(0);    opacity: 1; }
    }
    .modal-title {
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 6px;
        font-family: 'Space Grotesk', sans-serif;
    }
    .modal-subtitle { font-size: 13px; color: #888; margin-bottom: 20px; }
    .reason-option {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 11px 14px;
        border: 1.5px solid #e8e8e8;
        border-radius: 7px;
        margin-bottom: 8px;
        cursor: pointer;
        transition: border-color .15s;
        font-size: 13px;
        font-weight: 500;
    }
    .reason-option:has(input:checked) { border-color: #ef4444; background: #fff5f5; }
    .reason-option input[type="radio"] { accent-color: #ef4444; flex-shrink: 0; }
    .other-textarea {
        width: 100%;
        border: 1.5px solid #d4d4d4;
        border-radius: 7px;
        padding: 10px 12px;
        font-size: 13px;
        font-family: 'Inter', sans-serif;
        resize: vertical;
        min-height: 80px;
        outline: none;
        margin-top: 4px;
        box-sizing: border-box;
        transition: border-color .15s;
    }
    .other-textarea:focus { border-color: #ef4444; }
    .modal-actions {
        display: flex;
        gap: 10px;
        margin-top: 20px;
    }
    .modal-btn-cancel-action {
        flex: 1;
        background: #ef4444;
        color: #fff;
        border: none;
        padding: 12px;
        border-radius: 7px;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        font-family: 'Inter', sans-serif;
        transition: background .2s;
    }
    .modal-btn-cancel-action:hover { background: #dc2626; }
    .modal-btn-keep {
        flex: 1;
        border: 1.5px solid #d4d4d4;
        background: #fff;
        color: #0a0a0a;
        padding: 12px;
        border-radius: 7px;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        font-family: 'Inter', sans-serif;
        transition: all .2s;
    }
    .modal-btn-keep:hover { border-color: #0a0a0a; }

    @@media (max-width: 480px) {
        .info-grid { grid-template-columns: 1fr; }
        .detail-title { font-size: 20px; }
    }
</style>
}

<div class="detail-page">

    <a class="back-link" href="/Home/MyOrders">← Back to My Orders</a>

    @if (TempData["SuccessMessage"] != null)
    {
        <div style="background:#f0fdf4;border:1px solid #86efac;color:#166534;padding:12px 16px;border-radius:7px;margin-bottom:20px;font-size:13px;">
            ✅ @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div style="background:#fef2f2;border:1px solid #fca5a5;color:#b91c1c;padding:12px 16px;border-radius:7px;margin-bottom:20px;font-size:13px;">
            ⚠️ @TempData["ErrorMessage"]
        </div>
    }

    <div class="detail-header">
        <div>
            <div class="detail-title">Order #@Model.OrderId</div>
            <div class="detail-date">Placed on @Model.CreatedAt.ToString("MMMM d, yyyy 'at' h:mm tt")</div>
        </div>
        <span class="status-pill-lg"
              style="background:@(Model.StatusColor)22; color:@Model.StatusColor;">
            <span class="status-dot-lg"></span>
            @Model.OrderStatus
        </span>
    </div>

    <!-- Order Tracking -->
    <div class="detail-card">
        <div class="detail-section">
            <div class="section-title">Order Tracking</div>
            @{
                var statuses = new[] { "Placed", "Processing", "Shipped", "Delivered" };
                var icons    = new[] { "📋", "⚙️", "🚚", "📦" };
                int current  = Model.CurrentStep;
            }
            <div class="track-steps">
                @for (int i = 0; i < statuses.Length; i++)
                {
                    bool isActive = i == current;
                    bool isDone   = i < current;
                    <div class="track-step @(i <= current ? "done" : "")">
                        <div class="track-dot @(isActive ? "active" : isDone ? "done-bg" : "")">
                            @if (i == 3)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                     stroke="@(isActive ? "#fff" : "#0a0a0a")" stroke-width="1.8"
                                     stroke-linecap="round" stroke-linejoin="round"
                                     width="18" height="18">
                                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                                    <line x1="12" y1="22.08" x2="12" y2="12"/>
                                    <polyline points="9 12 11 14.5 15.5 9.5"
                                              stroke="@(isActive ? "#fff" : "#16a34a")" stroke-width="2.5"/>
                                </svg>
                            }
                            else
                            {
                                @icons[i]
                            }
                        </div>
                        <span class="track-label">@statuses[i]</span>
                    </div>
                }
            </div>
            <p style="font-size:12px;color:#888;margin-top:10px;text-align:center;">
                @if (Model.OrderStatus == "Placed")
                {
                    <span>Your order has been placed and will be processed soon.</span>
                }
                else if (Model.OrderStatus == "Processing")
                {
                    <span>We are preparing your order for shipment.</span>
                }
                else if (Model.OrderStatus == "Shipped")
                {
                    <span>Your order is on its way!</span>
                }
                else
                {
                    <span>Your order has been delivered. Enjoy!</span>
                }
            </p>
        </div>
    </div>

    <!-- Shipping & Payment -->
    <div class="detail-card">
        <div class="detail-section">
            <div class="section-title">Shipping Information</div>
            <div class="info-grid">
                <div>
                    <div class="info-label">Full Name</div>
                    <div class="info-value">@Model.FullName</div>
                </div>
                <div>
                    <div class="info-label">Phone</div>
                    <div class="info-value">@(string.IsNullOrEmpty(Model.Phone) ? "—" : Model.Phone)</div>
                </div>
                <div style="grid-column:1/-1;">
                    <div class="info-label">Address</div>
                    <div class="info-value">@Model.Address, @Model.City @Model.PostalCode</div>
                </div>
                <div>
                    <div class="info-label">Email</div>
                    <div class="info-value">@Model.Email</div>
                </div>
                <div>
                    <div class="info-label">Delivery Option</div>
                    <div class="info-value">@(Model.DeliveryOption == "Express" ? "Express (1–2 days)" : "Standard (3–5 days)")</div>
                </div>
            </div>
        </div>
        <div class="detail-section">
            <div class="section-title">Payment Method</div>
            <div class="payment-badge">
                @if (Model.PaymentMethod == "Card")
                {
                    <span>💳</span>
                }
                else if (Model.PaymentMethod == "PayPal")
                {
                    <span>🅿️</span>
                }
                else
                {
                    <span>💵</span>
                }
                @Model.PaymentMethod
            </div>
        </div>
    </div>

    <!-- Items Ordered -->
    <div class="detail-card">
        <div class="detail-section">
            <div class="section-title">Items Ordered</div>
            @foreach (var item in Model.OrderItems)
            {
                <div class="detail-item">
                    <img class="detail-item-img"
                         src="@item.Image" alt="@item.Name"
                         onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 width=%27200%27 height=%27200%27%3E%3Crect width=%27200%27 height=%27200%27 fill=%27%23f5f5f5%27/%3E%3C/svg%3E'" />
                    <div class="detail-item-info">
                        <div class="detail-item-name">@item.Name</div>
                        <div class="detail-item-sub">Size: @item.Size</div>
                        <div class="detail-item-qty">Qty: @item.Quantity</div>
                    </div>
                    <div class="detail-item-price">₱@((item.Price * item.Quantity).ToString("N0"))</div>
                </div>
            }
        </div>
    </div>

    <!-- Order Summary -->
    <div class="detail-card">
        <div class="detail-section">
            <div class="section-title">Order Summary</div>
            <div class="total-row"><span>Subtotal</span><span>₱@Model.Subtotal.ToString("N0")</span></div>
            <div class="total-row"><span>Shipping (@Model.DeliveryOption)</span><span>₱@Model.ShippingFee.ToString("N0")</span></div>
            <div class="total-row grand"><span>Total</span><span>₱@Model.Total.ToString("N0")</span></div>
        </div>
    </div>

    <!-- Actions -->
    <div class="detail-actions">
        <a class="btn-outline" href="/Home/MyOrders">← My Orders</a>
        @if (Model.OrderStatus == "Cancelled")
        {
            @if (!string.IsNullOrEmpty(Model.CancellationReason))
            {
                <div style="width:100%;background:#fef2f2;border:1px solid #fca5a5;border-radius:7px;padding:12px 16px;font-size:13px;color:#b91c1c;">
                    <strong>Cancellation Reason:</strong> @Model.CancellationReason
                </div>
            }
        }
        else if (Model.OrderStatus == "Placed")
        {
            <button type="button" class="btn-cancel" onclick="openCancelModal()">Cancel Order</button>
        }
        else
        {
            <button type="button" class="btn-cancel" disabled title="Order cannot be cancelled once processing has started">Cancel Order</button>
        }
        <a class="btn-black" href="/Home/Shop">Continue Shopping</a>
    </div>

</div>

<!-- Cancel Order Modal -->
<div class="modal-overlay" id="cancelModal">
    <div class="modal-box">
        <div class="modal-title">Cancel Order</div>
        <div class="modal-subtitle">Please select a reason for cancelling order <strong>@Model.OrderId</strong>.</div>

        <form method="post" asp-controller="Home" asp-action="CancelOrder" id="cancelForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="orderId" value="@Model.OrderId" />
            <input type="hidden" name="cancellationReason" id="finalReason" />

            <label class="reason-option">
                <input type="radio" name="reasonChoice" value="Changed my mind" /> Changed my mind
            </label>
            <label class="reason-option">
                <input type="radio" name="reasonChoice" value="Ordered the wrong item" /> Ordered the wrong item
            </label>
            <label class="reason-option">
                <input type="radio" name="reasonChoice" value="Found a better price elsewhere" /> Found a better price elsewhere
            </label>
            <label class="reason-option">
                <input type="radio" name="reasonChoice" value="Delivery time is too long" /> Delivery time is too long
            </label>
            <label class="reason-option">
                <input type="radio" name="reasonChoice" value="other" id="otherRadio" /> Other reason
            </label>

            <div id="otherTextWrap" style="display:none;margin-top:4px;">
                <textarea class="other-textarea" id="otherText" placeholder="Please describe your reason…"></textarea>
            </div>

            <div class="modal-actions">
                <button type="button" class="modal-btn-keep" onclick="closeCancelModal()">Keep Order</button>
                <button type="button" class="modal-btn-cancel-action" onclick="submitCancel()">Confirm Cancel</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function openCancelModal() {
        document.getElementById('cancelModal').classList.add('open');
    }
    function closeCancelModal() {
        document.getElementById('cancelModal').classList.remove('open');
    }
    document.getElementById('cancelModal').addEventListener('click', function (e) {
        if (e.target === this) closeCancelModal();
    });
    document.querySelectorAll('input[name="reasonChoice"]').forEach(function (radio) {
        radio.addEventListener('change', function () {
            document.getElementById('otherTextWrap').style.display =
                this.value === 'other' ? 'block' : 'none';
        });
    });
    function submitCancel() {
        const selected = document.querySelector('input[name="reasonChoice"]:checked');
        if (!selected) {
            alert('Please select a reason for cancellation.');
            return;
        }
        let reason = selected.value;
        if (reason === 'other') {
            const txt = document.getElementById('otherText').value.trim();
            if (!txt) {
                alert('Please describe your reason for cancellation.');
                return;
            }
            reason = txt;
        }
        document.getElementById('finalReason').value = reason;
        document.getElementById('cancelForm').submit();
    }
</script>
}
