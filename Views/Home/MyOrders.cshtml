@model IEnumerable<MyAspNetApp.Models.OrderConfirmationViewModel>

@{
    ViewData["Title"] = "My Orders";
}

@section Styles {
<style>
    .orders-page {
        max-width: 800px;
        margin: 0 auto;
        padding: 40px 24px 80px;
    }

    .orders-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: 32px;
    }
    .orders-title {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 30px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
    }
    .orders-count { font-size: 13px; color: #888; }

    /* Status filter tabs */
    .status-tabs {
        display: flex;
        gap: 8px;
        margin-bottom: 24px;
        border-bottom: 1px solid #e8e8e8;
        overflow-x: auto;
    }
    .status-tab {
        padding: 8px 16px;
        font-size: 13px;
        font-weight: 600;
        border: none;
        background: none;
        cursor: pointer;
        color: #888;
        border-bottom: 2px solid transparent;
        margin-bottom: -1px;
        font-family: 'Inter', sans-serif;
        transition: all .15s;
        white-space: nowrap;
    }
    .status-tab:hover { color: #0a0a0a; }
    .status-tab.active { color: #0a0a0a; border-bottom-color: #0a0a0a; }

    /* Order card */
    .order-card {
        border: 1.5px solid #e8e8e8;
        border-radius: 10px;
        padding: 20px 24px;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 20px;
        text-decoration: none;
        color: inherit;
        transition: box-shadow .2s, transform .15s, border-color .2s;
        background: #fff;
    }
    .order-card:hover {
        box-shadow: 0 6px 24px rgba(0,0,0,.08);
        transform: translateY(-2px);
        border-color: #d4d4d4;
        color: inherit;
    }

    .order-status-icon {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        flex-shrink: 0;
        background: #f5f5f5;
    }

    .order-info { flex: 1; }
    .order-id { font-size: 13px; font-weight: 700; margin-bottom: 4px; color: #0a0a0a; }
    .order-meta {
        font-size: 12px;
        color: #888;
        margin-bottom: 6px;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }
    .order-address { font-size: 12px; color: #3a3a3a; margin-bottom: 8px; }

    /* Progress bar */
    .mini-progress { display: flex; gap: 3px; }
    .mini-step { height: 3px; flex: 1; border-radius: 2px; background: #e8e8e8; }
    .mini-step.done { background: #0a0a0a; }

    .order-right {
        text-align: right;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 8px;
    }
    .order-total { font-size: 18px; font-weight: 700; color: #0a0a0a; }

    .status-pill {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: .3px;
    }
    .status-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }

    .view-btn {
        font-size: 12px;
        font-weight: 600;
        color: #0a0a0a;
        display: flex;
        align-items: center;
        gap: 4px;
    }
    .view-btn::after { content: ' →'; }

    /* Empty state */
    .empty-orders { text-align: center; padding: 80px 20px; color: #888; }
    .empty-icon { font-size: 56px; margin-bottom: 16px; }
    .empty-orders h2 { font-size: 20px; color: #0a0a0a; margin-bottom: 8px; }
    .empty-orders p { font-size: 14px; margin-bottom: 24px; }
    .btn-shop {
        display: inline-block;
        padding: 12px 28px;
        background: #0a0a0a;
        color: #fff;
        text-decoration: none;
        border-radius: 6px;
        font-weight: 700;
        font-size: 14px;
        font-family: 'Inter', sans-serif;
    }

    @@media (max-width: 600px) {
        .order-card { flex-wrap: wrap; }
        .order-right { align-items: flex-start; }
    }
</style>
}

<div class="orders-page">

    <div class="orders-header">
        <div class="orders-title">My Orders</div>
        <div class="orders-count">@Model.Count() order(s)</div>
    </div>

    <div class="status-tabs">
        <button class="status-tab active" onclick="filterOrders('all', this)">All</button>
        <button class="status-tab" onclick="filterOrders('Placed', this)">Placed</button>
        <button class="status-tab" onclick="filterOrders('Processing', this)">Processing</button>
        <button class="status-tab" onclick="filterOrders('Shipped', this)">Shipped</button>
        <button class="status-tab" onclick="filterOrders('Delivered', this)">Delivered</button>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-orders">
            <div class="empty-icon">📦</div>
            <h2>No orders yet</h2>
            <p>You haven't placed any orders. Start shopping!</p>
            <a class="btn-shop" href="/Home/Shop">Browse Products</a>
        </div>
    }
    else
    {
        var statuses = new[] { "Placed", "Processing", "Shipped", "Delivered" };

        <div id="orders-list">
            @foreach (var order in Model)
            {
                int step = Array.IndexOf(statuses, order.OrderStatus);
                if (step < 0) step = 0;

                string icon = order.OrderStatus switch
                {
                    "Placed"     => "📋",
                    "Processing" => "⚙️",
                    "Shipped"    => "🚚",
                    "Delivered"  => "✅",
                    _            => "📦"
                };

                <a class="order-card"
                   data-status="@order.OrderStatus"
                   href="/Home/OrderDetail?id=@order.OrderId">

                    <div class="order-status-icon">@icon</div>

                    <div class="order-info">
                        <div class="order-id">@order.OrderId</div>
                        <div class="order-meta">
                            <span>📅 @order.CreatedAt.ToString("MMM d, yyyy")</span>
                            <span>🚚 @order.DeliveryOption</span>
                        </div>
                        <div class="order-address">📍 @order.Address, @order.City @order.PostalCode</div>
                        <div class="mini-progress">
                            @for (int i = 0; i < statuses.Length; i++)
                            {
                                <div class="mini-step @(i <= step ? "done" : "")"></div>
                            }
                        </div>
                    </div>

                    <div class="order-right">
                        <div class="order-total">₱@order.Total.ToString("N0")</div>
                        <span class="status-pill"
                              style="background:@(order.StatusColor)22; color:@order.StatusColor;">
                            <span class="status-dot"></span>
                            @order.OrderStatus
                        </span>
                        <span class="view-btn">View Details</span>
                    </div>
                </a>
            }
        </div>
    }

</div>

@section Scripts {
<script>
    function filterOrders(status, btn) {
        document.querySelectorAll('.status-tab').forEach(t => t.classList.remove('active'));
        btn.classList.add('active');
        document.querySelectorAll('.order-card').forEach(card => {
            card.style.display = (status === 'all' || card.dataset.status === status) ? 'flex' : 'none';
        });
    }
</script>
}
